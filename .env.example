# ═══════════════════════════════════════════════════════
# Overlord v2 — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── Server ───
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ─── Database ───
# SQLite (default) — path relative to project root
DB_PATH=./data/overlord.db
# Future: DB_URL=postgres://user:pass@localhost:5432/overlord

# ─── AI Providers ───
# Anthropic (primary for reasoning tasks)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# MiniMax (fast coding, cost-effective)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-Text-01

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Local / Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Default Provider Per Room Type ───
PROVIDER_DISCOVERY=anthropic
PROVIDER_ARCHITECTURE=anthropic
PROVIDER_CODE_LAB=minimax
PROVIDER_TESTING_LAB=minimax
PROVIDER_REVIEW=anthropic
PROVIDER_DEPLOY=anthropic

# ─── GitHub Integration ───
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# ─── MCP (Model Context Protocol) ───
MCP_SERVERS_CONFIG=./mcp-servers.json

# ─── Security ───
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:4000

# ─── Features ───
ENABLE_PLUGINS=false
ENABLE_LUA_SCRIPTING=false
PLUGIN_DIR=./plugins
