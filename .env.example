# ═══════════════════════════════════════════════════════
# Overlord v2 — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── Server ───
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ─── Database ───
# SQLite (default) — path relative to project root
DB_PATH=./data/overlord.db
# Future: DB_URL=postgres://user:pass@localhost:5432/overlord

# ─── AI Providers ───
# Anthropic (primary for reasoning tasks)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# MiniMax (fast coding, agent teams, cost-effective)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Local / Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Default Provider Per Room Type ───
PROVIDER_DISCOVERY=anthropic
PROVIDER_ARCHITECTURE=anthropic
PROVIDER_CODE_LAB=minimax
PROVIDER_TESTING_LAB=minimax
PROVIDER_REVIEW=anthropic
PROVIDER_DEPLOY=anthropic

# ─── GitHub Integration ───
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# ─── MCP (Model Context Protocol) ───
MCP_SERVERS_CONFIG=./mcp-servers.json

# ─── Security ───
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:4000

# ─── Features ───
ENABLE_PLUGINS=false
ENABLE_LUA_SCRIPTING=false
PLUGIN_DIR=./plugins

# ─── Agent Conversation Loop ───
# Max tool execution cycles per conversation turn (default: 200)
MAX_TOOL_ITERATIONS=200
# Timeout per individual tool execution in ms (default: 120000 = 2 min)
TOOL_TIMEOUT_MS=120000
# Max retry attempts on transient AI errors (default: 5)
AI_MAX_RETRIES=5
# Base retry delay in ms, doubles each retry (default: 1000)
AI_RETRY_DELAY_MS=1000

# ─── Shell Tool ───
# Shell command timeout in ms (default: 120000 = 2 min)
SHELL_TIMEOUT_MS=120000
# Max shell output size in bytes (default: 500000 = 500KB)
SHELL_MAX_OUTPUT=500000

# ─── Web Tool ───
# Max search results returned (default: 50)
WEB_MAX_RESULTS=50
# Max webpage text extraction length (default: 500000 = 500KB)
WEB_MAX_LENGTH=500000
# Max response body size in bytes (default: 5242880 = 5MB)
WEB_MAX_RESPONSE_BODY=5242880

# ─── Plugin Sandboxes ───
# JS plugin execution timeout in ms (default: 30000)
PLUGIN_TIMEOUT_MS=30000
# Max allowed plugin timer duration in ms (default: 60000)
PLUGIN_MAX_TIMEOUT_MS=60000
# Lua plugin execution timeout in ms (default: 30000)
LUA_TIMEOUT_MS=30000

# ─── Escalation ───
# How often to check for stale phase gates in ms (default: 300000 = 5 min)
ESCALATION_INTERVAL_MS=300000
# Gate age before considered stale in ms (default: 1800000 = 30 min)
ESCALATION_THRESHOLD_MS=1800000

# ─── Log Broadcasting ───
# Rate limit window for log broadcasts in ms (default: 1000)
LOG_WINDOW_MS=1000
# Max log entries broadcast per window (default: 50)
MAX_LOGS_PER_WINDOW=50
