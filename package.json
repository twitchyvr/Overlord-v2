{
  "name": "overlord-v2",
  "version": "0.1.0",
  "description": "Overlord v2 — Building/Room/Table agentic framework. Scriptable, scalable, provider-agnostic.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "validate": "npm run typecheck && npm run lint && npm run test"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "rooms",
    "framework",
    "multi-agent",
    "provider-agnostic",
    "typescript"
  ],
  "author": "twitchyvr",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.8.0",
    "dotenv": "^16.4.7",
    "eventemitter3": "^5.0.1",
    "express": "^5.0.1",
    "openai": "^6.27.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.0",
    "wasmoon": "^1.16.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.20.0",
    "globals": "^16.0.0",
    "jsdom": "^28.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.0",
    "@playwright/test": "^1.58.2"
  }
}
